{
    "buildCommand": "npm run vercel-build",
    "outputDirectory": "dist/client",
    "functions": {
        "api/index.ts": {
            "runtime": "@vercel/node@5.1.8",
            "includeFiles": "dist/server/**"
        }
    },
    "rewrites": [
        {
            "source": "/privacy",
            "destination": "/privacy.html"
        },
        {
            "source": "/(.*)",
            "destination": "/api/index"
        }
    ]
}